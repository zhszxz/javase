<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
<bean id="user" class="com.bistu.spring6iocxml.lifecycle.User" scope="singleton" init-method="init" destroy-method="destroy">
    <property name="name" value="lucy"></property>
</bean>
<!--    后置处理器，属于整个容器而不是某个bean对象-->
    <bean id="myBeanPost" class="com.bistu.spring6iocxml.lifecycle.MyBeanPost" ></bean>
</beans>